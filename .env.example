# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=opencctv
POSTGRES_USER=opencctv
POSTGRES_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

# ── OvenMediaEngine stream bases ──────────────────────────────────────────────
# Replace with your server's public IP or domain
OME_WEBRTC_BASE=ws://YOUR_SERVER_IP:3333
OME_LLHLS_BASE=http://YOUR_SERVER_IP:3334

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated JSON list of allowed frontend origins
CORS_ORIGINS=["http://YOUR_SERVER_IP:3000"]

# ── Admin user (created automatically on first startup) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# ── go2rtc ───────────────────────────────────────────────────────────────────
# Streaming endpoint proxied by the frontend nginx (stream.html, MSE WS, WebRTC)
# Format: host:port  (e.g. 192.168.1.10:1984)
GO2RTC_HOST=YOUR_SERVER_IP:1984
# Admin/API endpoint for the /go2rtc/ path
GO2RTC_ADMIN_HOST=YOUR_SERVER_IP:5000
# RTSP host:port that Frigate uses to pull streams from go2rtc (usually localhost)
GO2RTC_RTSP_HOST=127.0.0.1:8554

# ── Model initializer ────────────────────────────────────────────────────────
# SKIP_MODEL_DOWNLOAD=1   Skip model downloads entirely (if models already on host)
# FORCE_MODEL_DOWNLOAD=1  Re-download even if /models/.initialized exists
SKIP_MODEL_DOWNLOAD=0
FORCE_MODEL_DOWNLOAD=0

# ── Port overrides (optional) ─────────────────────────────────────────────────
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
# MQTT_PORT=1883
