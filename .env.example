# PostgreSQL
POSTGRES_DB=opencctv
POSTGRES_USER=opencctv
POSTGRES_PASSWORD=changeme_strong_password

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

# OvenMediaEngine stream bases
# In production, replace localhost with your server's public IP or domain
OME_WEBRTC_BASE=ws://localhost:3333
OME_LLHLS_BASE=http://localhost:3334

# CORS — comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:3000","https://cctv.example.com"]

# Default admin user — created automatically on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Model initializer ────────────────────────────────────────────────────────
# SKIP_MODEL_DOWNLOAD=1   Skip model downloads entirely (if models already on host)
# FORCE_MODEL_DOWNLOAD=1  Re-download even if /models/.initialized exists
SKIP_MODEL_DOWNLOAD=0
FORCE_MODEL_DOWNLOAD=0

# ── Port overrides (optional) ────────────────────────────────────────────────
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
# MQTT_PORT=1883
